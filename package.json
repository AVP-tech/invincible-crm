{
  "name": "invincible-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/render-postgres-schema.mjs && prisma generate --schema prisma/schema.postgres.prisma && prisma db push --schema prisma/schema.postgres.prisma --accept-data-loss && node scripts/backfill-workspace-ids.mjs && next build",
    "build:local": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "jobs:worker": "tsx src/worker/process-jobs.ts",
    "db:generate": "prisma generate",
    "db:generate:pg": "node scripts/render-postgres-schema.mjs && prisma generate --schema prisma/schema.postgres.prisma",
    "db:backfill:workspace": "node scripts/backfill-workspace-ids.mjs",
    "db:push": "prisma db push --accept-data-loss && node scripts/backfill-workspace-ids.mjs",
    "db:push:pg": "node scripts/render-postgres-schema.mjs && prisma db push --schema prisma/schema.postgres.prisma --accept-data-loss && node scripts/backfill-workspace-ids.mjs",
    "db:migrate": "prisma db push --accept-data-loss && node scripts/backfill-workspace-ids.mjs",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.62",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.17.1",
    "ai": "^6.0.158",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "imapflow": "^1.2.18",
    "lucide-react": "^0.554.0",
    "mailparser": "^3.9.6",
    "nanoid": "^5.1.6",
    "next": "^15.5.4",
    "openai": "^6.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "postcss": "^8.5.6",
    "prisma": "^6.17.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
